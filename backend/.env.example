# Copy this file to .env and fill in your values

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/emi-products

# Server port (hosting platforms usually set this automatically)
PORT=5000

# Allowed frontend origin(s) — comma-separated for multiple
# e.g. FRONTEND_URL=https://your-app.vercel.app,https://your-app-preview.vercel.app
FRONTEND_URL=http://localhost:5173
